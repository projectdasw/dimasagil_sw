msgstr "Elk item in de structuur moet een sectieobject zijn met \"children\". Voorbeeld: {\"columns\":[20,60,20],\"children\":[{\"type\":\"widget\",\"widget_type\":\"site-logo\",\"settings\":{}}]}"

